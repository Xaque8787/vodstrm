# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# JWT signing secret — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Path to the SQLite database file (relative to the project root)
DATABASE_PATH=data/app.db

# Port the application listens on
APP_PORT=8000

# Set to "true" to enable debug mode (enables /docs, verbose logging)
DEBUG=false

# JWT token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set to "true" when running behind HTTPS to mark cookies as Secure
SECURE_COOKIES=false

# Timezone for the scheduler (IANA timezone name)
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values
TZ=America/Los_Angeles

# Path to the SQLite database used by APScheduler for persistent job storage
SCHEDULER_DB_PATH=data/scheduler.db

# Directory where downloaded M3U playlist files are stored
M3U_DOWNLOAD_PATH=data/m3u
